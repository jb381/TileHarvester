# TileHarvester Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: Strava API Credentials
# =============================================================================
# Get these from https://www.strava.com/settings/api
TH_STRAVA_CLIENT_ID=your-client-id-here
TH_STRAVA_CLIENT_SECRET=your-client-secret-here

# =============================================================================
# OPTIONAL: OAuth & Data
# =============================================================================
# TH_STRAVA_REDIRECT_URI=http://localhost:8000/callback
# TH_DATA_DIR=~/.local/share/tileharvester

# =============================================================================
# OPTIONAL: Tile Engine
# =============================================================================
# Mapbox/XYZ zoom levels. Squadrats uses z14, Squadratinhos use z17.
# Only change if you know what you're doing.
# TH_SQUADRAT_ZOOM=14
# TH_SQUADRATINHO_ZOOM=17

# Offset to add to lifetime Squadrat totals (e.g. +5 or -3).
# Use this if your counts drift from the official Squadrats numbers.
# TH_SQUADRAT_OFFSET=0

# =============================================================================
# OPTIONAL: Sync Behavior
# =============================================================================
# How often sync runs (minutes). Used by cron and systemd timer.
# TH_POLL_INTERVAL_MINUTES=5

# Safety limit for backfill activities per run.
# TH_BACKFILL_PER_RUN=100

# Buffer before hitting Strava's daily rate limit.
# TH_RATE_LIMIT_BUFFER=10

# Sport types to ignore (comma-separated).
# TH_IGNORED_SPORT_TYPES=VirtualRide,VirtualRun

# GPS stream cleaning thresholds.
# TH_STREAM_MAX_SEGMENT_METERS=300.0
# TH_STREAM_MAX_TIME_GAP_SECONDS=60
# TH_STREAM_MAX_SPEED_MPS=35.0
# TH_STREAM_GAP_MIN_METERS=50.0

# =============================================================================
# OPTIONAL: Description Format
# =============================================================================
# TH_DESCRIPTION_PREFIX=🗺️ TileHarvester
# TH_DESCRIPTION_EMOJI=🗺️

# If true, rewrite old Strava descriptions when tiles are recomputed.
# Default is false — only new activities get annotated.
# TH_REWRITE_EXISTING_ANNOTATIONS=false
